# Application Logs
*.log
logs/
log/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Cache
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.cache

# Temporary Files
tmp/
temp/
.tmp/
.temp/
*.tmp
*.temp
*.bak
*.swp
*.swo

