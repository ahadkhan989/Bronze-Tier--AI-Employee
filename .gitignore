# =============================================================================
# AI Employee - Comprehensive .gitignore
# =============================================================================
# This file ensures no sensitive data, credentials, or large binary files
# are accidentally committed to the repository.
# =============================================================================

# =============================================================================
# PYTHON & DEVELOPMENT
# =============================================================================
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
*.egg

# Virtual environments
env/
venv/
ENV/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Build artifacts
build/
dist/
downloads/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg
.installed.cfg
*.egg-info

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Jupyter Notebook
.ipynb_checkpoints

# =============================================================================
# SENSITIVE FILES - NEVER COMMIT THESE
# =============================================================================

# Environment Variables (CONTAINS SECRETS)
.env
.env.local
.env.development
.env.production
.env.test
*.env

# Google OAuth Credentials
credentials.json
token.json
client_secret.json
service_account.json
*_credentials.json
*_credential.json
google_credentials.json

# Facebook/Meta Credentials
.facebook_token
.fb_access_token
instagram_access_token

# Twitter/X Credentials
.twitter_token
.twitter_credentials
twitter_*.json

# LinkedIn Credentials
.linkedin_token
.linkedin_credentials
linkedin_*.json

# Generic API Keys
*_key.json
*_keys.json
*_secret.json
*_secrets.json
*_api_key.json
*_api_secret.json
*.pem
*.key
*.p12
*.pfx

# Database Files
*.sqlite
*.sqlite3
*.db
*.sql

# =============================================================================
# AI EMPLOYEE VAULT - SENSITIVE FOLDERS
# =============================================================================

# Session Data (Contains Login Cookies & Tokens)
AI_Employee_Vault/token.json
AI_Employee_Vault/linkedin_session/
AI_Employee_Vault/whatsapp_session/
AI_Employee_Vault/facebook_session/
AI_Employee_Vault/twitter_session/
AI_Employee_Vault/google_session/
AI_Employee_Vault/browser_session/
AI_Employee_Vault/*_session/

# Logs (May Contain Sensitive Data)
AI_Employee_Vault/Logs/
AI_Employee_Vault/*.log
AI_Employee_Vault/**/*.log

# Active Processing Folders (Contain Raw Data)
AI_Employee_Vault/Inbox/
AI_Employee_Vault/Needs_Action/
AI_Employee_Vault/Pending_Approval/
AI_Employee_Vault/Approved/
AI_Employee_Vault/Rejected/
AI_Employee_Vault/In_Progress/

# Processed IDs (Tracking Files)
AI_Employee_Vault/*_processed_ids.json
AI_Employee_Vault/processed_*.json

# =============================================================================
# AI EMPLOYEE VAULT - COMMIT THESE (Structure & Templates)
# =============================================================================
# Keep these tracked for structure:
# AI_Employee_Vault/Dashboard.md
# AI_Employee_Vault/Company_Handbook.md
# AI_Employee_Vault/Business_Goals.md
# AI_Employee_Vault/Templates/
# AI_Employee_Vault/Done/ (completed items - optional)
# AI_Employee_Vault/Briefings/ (sanitized versions)
# AI_Employee_Vault/Plans/ (approved plans - sanitized)
# AI_Employee_Vault/Accounting/ (sanitized reports)
# AI_Employee_Vault/Invoices/ (templates only)
# AI_Employee_Vault/Customers/ (templates only)

# =============================================================================
# ODOO & DOCKER
# =============================================================================

# Odoo Data (Contains Database Files)
odoo/
odoo-data/
*.odoo

# PostgreSQL Data
postgres/
postgres-data/
*.postgres

# PGAdmin Data
pgadmin/
pgadmin-data/

# Docker
docker-compose.override.yml
.docker/
*.docker

# Docker volumes (if using local directories)
# Note: Named volumes are managed by Docker, not git

