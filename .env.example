# =============================================================================
# AI Employee Gold Tier - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Odoo ERP Configuration
# -----------------------------------------------------------------------------
ODOO_URL=http://localhost:8069
ODOO_DB=odoo-db
ODOO_USERNAME=admin
ODOO_PASSWORD=CHANGE_THIS_PASSWORD
ODOO_ADMIN_PASSWORD=CHANGE_THIS_TOO

# -----------------------------------------------------------------------------
# Gmail API Configuration (from Silver Tier)
# -----------------------------------------------------------------------------
# Get these from Google Cloud Console: https://console.cloud.google.com/
GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here
GMAIL_REDIRECT_URI=http://localhost

# -----------------------------------------------------------------------------
# Facebook/Meta Configuration
# -----------------------------------------------------------------------------
# Get these from Facebook Developers: https://developers.facebook.com/
FACEBOOK_APP_ID=your_app_id_here
FACEBOOK_APP_SECRET=your_app_secret_here
FACEBOOK_ACCESS_TOKEN=your_access_token_here
FACEBOOK_PAGE_ID=your_page_id_here
INSTAGRAM_ACCOUNT_ID=your_ig_account_id_here

# -----------------------------------------------------------------------------
# Twitter API Configuration
# -----------------------------------------------------------------------------
# Get these from Twitter Developer Portal: https://developer.twitter.com/
TWITTER_BEARER_TOKEN=your_bearer_token_here
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_SECRET=your_access_secret_here

# -----------------------------------------------------------------------------
# LinkedIn Configuration (from Silver Tier)
# -----------------------------------------------------------------------------
# LinkedIn API credentials
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here
LINKEDIN_ACCESS_TOKEN=your_access_token_here

# -----------------------------------------------------------------------------
# Security & Rate Limiting
# -----------------------------------------------------------------------------
# Dry run mode (prevents actual actions)
DRY_RUN=false

# Rate limits
MAX_EMAILS_PER_HOUR=10
MAX_POSTS_PER_DAY=5
MAX_TWEETS_PER_HOUR=20
MAX_ODOO_ACTIONS_PER_HOUR=50

# Approval thresholds
AUTO_APPROVE_EMAIL_UNDER=0
AUTO_APPROVE_PAYMENT_UNDER=0

# -----------------------------------------------------------------------------
# System Configuration
# -----------------------------------------------------------------------------
# Vault path (optional, can be passed as argument)
VAULT_PATH=AI_Employee_Vault

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable/disable specific watchers
ENABLE_GMAIL_WATCHER=true
ENABLE_WHATSAPP_WATCHER=true
ENABLE_LINKEDIN_WATCHER=true
ENABLE_FACEBOOK_WATCHER=true
ENABLE_TWITTER_WATCHER=true
ENABLE_ODOO_WATCHER=true
ENABLE_FILESYSTEM_WATCHER=true
